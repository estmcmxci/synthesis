{
  "name": "@synthesis/resolver",
  "version": "0.1.0",
  "description": "Trust Resolution Layer — ENS identity resolution, trust scoring, and verification",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist",
    "dev": "tsx src/index.ts",
    "lint": "npx @biomejs/biome lint --write .",
    "format": "npx @biomejs/biome format --write ."
  },
  "dependencies": {
    "@worldcoin/agentkit": "^0.1.5",
    "@zerodev/permissions": "^5.6.3",
    "@zerodev/sdk": "^5.5.8",
    "permissionless": "^0.3.4",
    "pinata": "^1.5.0",
    "viem": "^2.33.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
